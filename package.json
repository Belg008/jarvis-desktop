{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "description": "JARVIS Desktop Assistant — Electron app for your AI butler",
  "main": "dist-electron/main.js",
  "author": "Sindre Belgum <sindre@belgum.me>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run build:electron && vite",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "me.sindbelg.jarvis",
    "productName": "JARVIS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
